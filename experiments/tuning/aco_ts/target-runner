#!/bin/bash

error() {
  echo "$(TZ=UTC date): $0: error: $@"
  exit 1
}

CONFIG_ID=$1
INSTANCE_ID=$2
SEED=$3
INSTANCE=$4
shift 4 || error "Not enough parameters"
CONFIG_PARAMS=$*

EXE=../../../build/Release/aco_ts_runner

OUT_DIR="../../../results/tuning/aco_ts"
mkdir -p "${OUT_DIR}"

INSTANCE_BASE=$(basename "${INSTANCE}")
JSON_NAME="${INSTANCE_BASE%.col}.json"
JSON_OUTPUT="${OUT_DIR}/${JSON_NAME}"

EXE_PARAMS="--input ${INSTANCE} --seed ${SEED} --output ${JSON_OUTPUT} ${CONFIG_PARAMS}"

if [ ! -x "$(command -v ${EXE})" ]; then
  error "${EXE}: not found or not executable (pwd: $(pwd))"
fi

STDOUT=c${CONFIG_ID}-${INSTANCE_ID}-${SEED}.stdout
STDERR=c${CONFIG_ID}-${INSTANCE_ID}-${SEED}.stderr

$EXE ${EXE_PARAMS} 1>${STDOUT} 2>${STDERR}

if [ ! -s "${STDOUT}" ]; then
  error "${STDOUT}: No such file or directory (O algoritmo falhou ou não gerou saída)"
fi

COST=$(tail -n 1 ${STDOUT} | grep -e '^[[:space:]]*[+-]\?[0-9]' | cut -f1)
echo "$COST"

exit 0
